# Copy this file to .env and fill in the values from Mobinet.
# .env is git-ignored so your credentials stay local.

# --- Required: your SIP account from Mobinet ---
SIP_DOMAIN=ip-phone.mobinet.mn
SIP_USER=          # your number / login — Mobinet uses the bare local number, e.g. 75151407 (not +976…)
SIP_PASS=          # your SIP password
# SIP_AUTH_USER=   # set only if the provider issued a separate auth/login name

# --- Optional (sensible defaults) ---
SIP_PORT=5060      # registrar port (5060 udp/tcp, 5061 tls)
SIP_TRANSPORT=udp  # udp | tcp | tls
SIP_EXPIRY=60      # requested registration lifetime, seconds

# Inbound forwarding: when set, callers who press 1 are bridged to this number.
FORWARD_TO=
FORWARD_CONCURRENCY=1   # max simultaneous forwards; extra callers wait in a queue
QUEUE_TIMEOUT=120       # seconds a queued caller waits on hold before giving up

# Audio clips — 8 kHz mono 16-bit WAV. Convert MP3 with:
#   ffmpeg -i in.mp3 -ar 8000 -ac 1 -c:a pcm_s16le out.wav
# A path that exists on disk is used; otherwise it falls back to a bundled demo.
PROMPT_FILE=sounds/start.wav                # greeting while waiting for the caller to press 1
CONNECTING_FILE=sounds/calling-forward.wav  # "connecting…" played while the forward leg rings
HOLD_FILE=sounds/waiting-queue.wav          # hold music while a caller waits in the queue

# --- Networking / NAT ---
# BIND_HOST = which LOCAL interface IP to bind to. Leave EMPTY to auto-detect.
# It must be an IP that exists on this host. Do NOT put a cloud public IP here if
# it isn't on the interface (1:1-NAT hosts) — that fails with "cannot assign
# requested address". Put the public IP in PUBLIC_HOST below instead.
BIND_HOST=
BIND_PORT=0        # 0 = OS picks a free SIP port. Deploying? Pin it, e.g. 5060.

# RTP/RTCP media UDP port range. 0/0 = OS ephemeral (random) ports. Pin a range
# when deploying behind a firewall, then open exactly these UDP ports.
RTP_PORT_START=0   # e.g. 10000
RTP_PORT_END=0     # e.g. 10100

# Public IP advertised in SDP so inbound RTP can return through NAT.
# Empty = auto-discover via STUN. Set explicitly if STUN is wrong/blocked.
PUBLIC_HOST=
STUN_SERVER=stun.l.google.com:19302   # empty string disables STUN discovery

# HTTP control API (Chi + Huma v2). Interactive docs at http://<host>:8080/docs.
HTTP_ADDR=:8080        # listen address; set empty to disable the API

# SMS via Mobinet's web portal (NOT SIP). Set SMS_PASS to enable POST /sms.
SMS_PORTAL_URL=https://phone.mobinet.mn
SMS_USER=              # portal login; defaults to SIP_USER if empty
SMS_PASS=              # portal password (your phone.mobinet.mn login)

# Set to "debug" to print SIP-level detail.
LOG_LEVEL=info
